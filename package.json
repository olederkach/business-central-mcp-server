{
  "name": "business-central-mcp-server",
  "version": "1.0.1",
  "type": "module",
  "description": "MCP server for Microsoft Dynamics 365 Business Central — use via npx or deploy on Azure",
  "main": "dist/index.js",
  "bin": {
    "business-central-mcp-server": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/server.ts",
    "dev:stdio": "tsx src/index.ts --stdio",
    "build": "npm run clean && tsc",
    "build:check": "tsc --noEmit",
    "build:prod": "npm run lint && npm run format:check && npm run type-check && npm run build",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "test:health": "curl -f http://localhost:3005/health || echo 'Server not running'",
    "test:mcp": "curl -X POST http://localhost:3005/mcp -H 'Content-Type: application/json' -H 'X-API-Key: dev-key' -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{}}'",
    "lint": "eslint src --ext .ts --config .eslintrc.json",
    "lint:fix": "eslint src --ext .ts --config .eslintrc.json --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" --config .prettierrc.json",
    "format:check": "prettier --check \"src/**/*.ts\" --config .prettierrc.json",
    "security:check": "npm audit --audit-level=moderate",
    "secrets:check": "echo 'No secrets scanning configured yet'",
    "prepublishOnly": "npm run build && npm run type-check",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "docker:build": "docker build -t business-central-mcp-server:latest -f config/Dockerfile .",
    "docker:run": "docker-compose -f config/docker-compose.yml up -d",
    "docker:stop": "docker-compose -f config/docker-compose.yml down",
    "docker:logs": "docker-compose -f config/docker-compose.yml logs -f",
    "deploy": "bash scripts/deployment/deploy-to-azure.sh",
    "rollback": "bash scripts/maintenance/emergency-rollback.sh",
    "rotate-secrets": "bash scripts/maintenance/rotate-secrets.sh",
    "verify": "bash scripts/maintenance/verify-deployment-readiness.sh"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "business-central",
    "dynamics-365",
    "microsoft",
    "copilot",
    "claude",
    "ai",
    "erp",
    "odata"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/olederkach/business-central-mcp-server"
  },
  "homepage": "https://github.com/olederkach/business-central-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/olederkach/business-central-mcp-server/issues"
  },
  "author": "Oleksandr Derkach",
  "license": "MIT",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-secrets": "^4.7.0",
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.20",
    "@azure/msal-node": "^2.6.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "applicationinsights": "^3.12.0",
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "lru-cache": "^10.0.0",
    "prom-client": "^15.0.0",
    "uuid": "^9.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-sonarjs": "^0.23.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
