# ============================================
# Business Central MCP Server Configuration
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# BUSINESS CENTRAL CREDENTIALS (required)
# ============================================

# Azure AD tenant GUID
BC_TENANT_ID=<your-tenant-id>

# Azure AD app registration for BC API access
BC_CLIENT_ID=<your-client-id>
BC_CLIENT_SECRET=<your-client-secret>

# BC environment name
BC_ENVIRONMENT_NAME=Sandbox

# Default company UUID (optional - use list_companies tool to discover)
# BC_COMPANY_ID=<your-company-id>

# ============================================
# API CONFIGURATION (optional)
# ============================================

# API version for standard BC API
API_VERSION=v2.0

# Default API context (leave empty for standard BC API v2.0)
# DEFAULT_API_PUBLISHER=microsoft
# DEFAULT_API_GROUP=automation
# DEFAULT_API_VERSION=v1.0

# Metadata parsing: all | extensions-only
METADATA_MODE=all

# Cache TTL for metadata (seconds)
CACHE_TTL_SECONDS=3600

# ============================================
# HTTP MODE ONLY (enterprise deployment)
# The settings below only apply when running
# in HTTP mode (without --stdio flag)
# ============================================

# Server
NODE_ENV=production
PORT=3005
LOG_LEVEL=info

# Client authentication mode: api-key | oauth
AUTH_MODE=api-key

# API keys for MCP client authentication (comma-separated)
# Generate: openssl rand -base64 32
# MCP_API_KEYS=<key1>,<key2>

# Azure Key Vault (recommended for production)
# KEY_VAULT_NAME=<your-keyvault-name>

# OAuth (if AUTH_MODE=oauth)
# AZURE_TENANT_ID=<your-tenant-id>
# AZURE_CLIENT_ID=<your-client-id>
# AZURE_CLIENT_SECRET=<your-client-secret>
# MCP_OAUTH_REQUIRED_SCOPE=MCP.Access
# MCP_SERVER_URL=https://<your-server>.azurecontainerapps.io

# CORS (comma-separated origins)
CORS_ORIGINS=https://powerplatform.microsoft.com,https://make.powerapps.com

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Monitoring
# APPLICATIONINSIGHTS_CONNECTION_STRING=<your-connection-string>

# Advanced
REQUEST_TIMEOUT_MS=30000
MAX_RESPONSE_SIZE=10485760

# ============================================
# QUICK REFERENCE
# ============================================
#
# npm/stdio mode (Claude Desktop, Claude Code):
#   Required: BC_TENANT_ID, BC_CLIENT_ID, BC_CLIENT_SECRET, BC_ENVIRONMENT_NAME
#   Optional: BC_COMPANY_ID
#
# HTTP mode (Copilot Studio, Azure AI Foundry):
#   Required: All above + MCP_API_KEYS (or KEY_VAULT_NAME)
#   Optional: AUTH_MODE, CORS_ORIGINS, RATE_LIMIT_*, APPLICATIONINSIGHTS_*
