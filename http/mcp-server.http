# ==============================================
# MCP TOOLS - API CONTEXT MANAGEMENT
# ==============================================

### List BC API Contexts
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 30,
  "method": "tools/call",
  "params": {
    "name": "list_bc_api_contexts",
    "arguments": {}
  }
}

### Get Active API
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 31,
  "method": "tools/call",
  "params": {
    "name": "get_active_api",
    "arguments": {}
  }
}

### Set Active API (switch to Microsoft Automation API)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 32,
  "method": "tools/call",
  "params": {
    "name": "set_active_api",
    "arguments": {
      "publisher": "microsoft",
      "group": "automation",
      "version": "v1.0"
    }
  }
}

### Set Active API (switch back to Standard BC API v2.0)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 33,
  "method": "tools/call",
  "params": {
    "name": "set_active_api",
    "arguments": {
      "publisher": "",
      "group": "",
      "version": "v2.0"
    }
  }
}

