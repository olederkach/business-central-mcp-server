# ==============================================
# MCP TOOLS - RESOURCE DISCOVERY
# ==============================================

### List Resources (entity names)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 50,
  "method": "tools/call",
  "params": {
    "name": "list_resources",
    "arguments": {}
  }
}

### Get OData Metadata (search for "customer")
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 51,
  "method": "tools/call",
  "params": {
    "name": "get_odata_metadata",
    "arguments": {
      "search": "customer",
      "search_type": "entity",
      "include_properties": true
    }
  }
}

### Get Resource Schema (customers entity)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 52,
  "method": "tools/call",
  "params": {
    "name": "get_resource_schema",
    "arguments": {
      "resource": "customers"
    }
  }
}

# ==============================================
# MCP TOOLS - CRUD OPERATIONS
# ==============================================

### List Records - Customers (top 5)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 60,
  "method": "tools/call",
  "params": {
    "name": "list_records",
    "arguments": {
      "resource": "customers",
      "top": 5,
      "select": "id,displayName,email,city,phoneNumber"
    }
  }
}

### List Records - Customers with filter
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 61,
  "method": "tools/call",
  "params": {
    "name": "list_records",
    "arguments": {
      "resource": "customers",
      "filter": "city eq 'Atlanta'",
      "top": 10,
      "orderby": "displayName asc"
    }
  }
}

### List Records - Items with substring search
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 62,
  "method": "tools/call",
  "params": {
    "name": "list_records",
    "arguments": {
      "resource": "items",
      "filter": "contains(displayName, 'bike')",
      "top": 10
    }
  }
}

### List Records - Sales Orders with expand
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 63,
  "method": "tools/call",
  "params": {
    "name": "list_records",
    "arguments": {
      "resource": "salesOrders",
      "expand": "salesOrderLines",
      "top": 5
    }
  }
}

### List Records - Vendors with pagination
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 64,
  "method": "tools/call",
  "params": {
    "name": "list_records",
    "arguments": {
      "resource": "vendors",
      "top": 20,
      "skip": 0,
      "orderby": "displayName asc"
    }
  }
}

### Find Records by Field (customer by email)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 65,
  "method": "tools/call",
  "params": {
    "name": "find_records_by_field",
    "arguments": {
      "resource": "customers",
      "field": "email",
      "value": "robert.townes@contoso.com"
    }
  }
}

### Create Record (new customer)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 66,
  "method": "tools/call",
  "params": {
    "name": "create_record",
    "arguments": {
      "resource": "customers",
      "data": {
        "displayName": "Test Customer",
        "email": "test@example.com",
        "city": "Seattle"
      }
    }
  }
}

### Update Record (replace record_id with actual UUID)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 67,
  "method": "tools/call",
  "params": {
    "name": "update_record",
    "arguments": {
      "resource": "customers",
      "record_id": "<record-uuid>",
      "data": {
        "phoneNumber": "+1-555-0100"
      }
    }
  }
}

### Delete Record (replace record_id with actual UUID)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 68,
  "method": "tools/call",
  "params": {
    "name": "delete_record",
    "arguments": {
      "resource": "customers",
      "record_id": "<record-uuid>"
    }
  }
}

# ==============================================
# OAUTH ENDPOINTS (when AUTH_MODE=oauth)
# ==============================================

### DCR - Register Client (public, no auth required - rate-limited only)
POST {{baseUrl}}/oauth/register
Content-Type: application/json

{
  "client_name": "test-client",
  "redirect_uris": ["https://example.com/callback"]
}

### DCR - List Registered Clients (requires auth)
GET {{baseUrl}}/oauth/clients
X-API-Key: {{apiKey}}

### OAuth Authorize (redirects to Azure AD)
# Open in browser: {{baseUrl}}/authorize?client_id=<client-id>&redirect_uri=<redirect-uri>&response_type=code&scope=openid

### OAuth Token Exchange (proxy to Azure AD)
POST {{baseUrl}}/token
Content-Type: application/x-www-form-urlencoded

grant_type=authorization_code&code=<auth-code>&redirect_uri=<redirect-uri>&client_id=<client-id>

# ==============================================
# USING BEARER TOKEN (OAuth flow)
# ==============================================

### Initialize with Bearer Token
# Replace <your-oauth-token> with a token from:
#   az account get-access-token --resource api://<your-client-id> --query accessToken -o tsv
# Or from the token endpoint:
#   POST https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
#   Body: client_id=...&client_secret=...&scope=api://<client-id>/.default&grant_type=client_credentials

POST {{baseUrl}}/mcp
Content-Type: application/json
Authorization: Bearer <your-oauth-token>

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-03-26",
    "capabilities": {},
    "clientInfo": {
      "name": "oauth-test",
      "version": "1.0.0"
    }
  }
}

# ==============================================
# URL-BASED MULTI-TENANT ENDPOINTS
# ==============================================

### Initialize via URL-based config (Standard BC API)
POST {{baseUrl}}/{{tenantId}}/{{environment}}/api/v2.0/companies(<company-uuid>)
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-03-26",
    "capabilities": {},
    "clientInfo": {
      "name": "url-config-test",
      "version": "1.0.0"
    }
  }
}

### Initialize via URL-based config (Custom/ISV API)
POST {{baseUrl}}/{{tenantId}}/{{environment}}/api/microsoft/automation/v1.0/companies(<company-uuid>)
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-03-26",
    "capabilities": {},
    "clientInfo": {
      "name": "custom-api-test",
      "version": "1.0.0"
    }
  }
}
