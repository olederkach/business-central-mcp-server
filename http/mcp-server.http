  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/list",
  "params": {}
}

### List Resources (4 contextual resources)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "resources/list",
  "params": {}
}

### List Prompts (12 workflow prompt templates)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "prompts/list",
  "params": {}
}

# ==============================================
# MCP PROTOCOL - RESOURCES (read)
# URI format: bc://{tenantId}/{environment}/{resource}
# Replace <tenant-id> and <environment> with your values
# ==============================================

@tenantId = <your-tenant-id>
@environment = Sandbox

### Read Resource: Companies List
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 5,
  "method": "resources/read",
  "params": {
    "uri": "bc://{{tenantId}}/{{environment}}/companies"
  }
}

### Read Resource: Entity Categories (available entity/resource names)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 6,
  "method": "resources/read",
  "params": {
    "uri": "bc://{{tenantId}}/{{environment}}/entities"
  }
}

### Read Resource: API Contexts (publisher/group/version combinations)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 7,
  "method": "resources/read",
  "params": {
    "uri": "bc://{{tenantId}}/{{environment}}/api-contexts"
  }
}

### Read Resource: Full API Metadata (OData EDMX)
POST {{baseUrl}}/mcp
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "jsonrpc": "2.0",
  "id": 8,
  "method": "resources/read",
  "params": {
    "uri": "bc://{{tenantId}}/{{environment}}/metadata"
  }
}

